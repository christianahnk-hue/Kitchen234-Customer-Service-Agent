# Kitchen234 Voice Agent — copy to .env and fill in
# Use a SEPARATE Supabase project + Render service from BluePeak
DATABASE_URL=
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
SERVER_URL=
VAPI_SERVER_SECRET=
OUTBOUND_API_KEY=
ELEVENLABS_VOICE_ID=
# CRITICAL for Setup B: must be a DIRECT line (manager cell), NEVER the main
# kitchen number - that number forwards to Nike and would create a loop!
TRANSFER_NUMBER=
# Kitchen234 needs its own number. Free Vapi numbers are capped at 1 per account
# (BluePeak used it) - so buy a Twilio number (~$1.15/mo) and use twilio mode
PHONE_MODE=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
RESEND_API_KEY=
NOTIFY_EMAIL=info@kitchen234.com
EMAIL_FROM=Kitchen234 Nike <onboarding@resend.dev>
PORT=3000
